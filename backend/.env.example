NODE_ENV=development
PORT=5000

# ── MongoDB ──────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/boutique

# ── JWT ──────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
